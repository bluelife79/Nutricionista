# ── CORS — Allowed frontend origin ───────────────────────────────────────────
# Railway/production: https://tu-app.vercel.app o https://revolucionat.railway.app
# Local dev: déjalo vacío para permitir localhost + file://
ALLOWED_ORIGIN=

# ── LLM Judge — provider switching ───────────────────────────────────────────
# The OpenAI SDK appends /chat/completions to base_url. So for GLM via z.ai
# (Coding Pro Yearly plan) the base_url must end at /v4 — the SDK will POST to
# https://api.z.ai/api/coding/paas/v4/chat/completions automatically.
LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
LLM_API_KEY=
LLM_MODEL=glm-5-turbo
LLM_TIMEOUT_MS=15000
LLM_TEMPERATURE=0.1

# ── LLM Judge — runtime ───────────────────────────────────────────────────────
LLM_JUDGE_ENABLED=true
LLM_MAX_CANDIDATES=30
LLM_CACHE_TTL_S=86400
LLM_CACHE_MAX_ENTRIES=1000

# ── LLM Judge — trigger thresholds (env-tunable, no redeploy needed) ─────────
LLM_JUDGE_TRIGGER_S1_CONFIDENCE_MAX=70
LLM_JUDGE_TRIGGER_S5_CALORIE_RATIO=1.0
LLM_JUDGE_TRIGGER_S6_SCORE_RATIO=0.3

# ── Switch to DeepSeek for production ────────────────────────────────────────
# Uncomment and set in Railway env vars (restart microservice after change):
#   LLM_BASE_URL=https://api.deepseek.com
#   LLM_MODEL=deepseek-v4-flash
#   LLM_API_KEY=<deepseek-key>
#
# DeepSeek uses the same OpenAI schema — only these 3 vars need changing.
# No code change, no redeploy of application code required.
