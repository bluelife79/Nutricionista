# ── Credentials ───────────────────────────────────────────────────────────────
# Required for bulk_label_foods.py (GLM-5-Turbo via Z.ai).
# Copy this file to .env and fill in your real key before running any script.
GLM_API_KEY=

# ── Microservicio de re-ranking semántico ─────────────────────────────────────
# Local dev: http://localhost:8000
# Railway: https://revolucionat-micro.railway.app
RERANK_API_URL=http://localhost:8000

# ── bulk-label-foods: API & batching ──────────────────────────────────────────
# Endpoint for GLM-5-Turbo via Z.ai international (use this, not bigmodel.cn).
BULK_LABEL_ENDPOINT=https://api.z.ai/api/coding/paas/v4/chat/completions
BULK_LABEL_MODEL=glm-5-turbo
BULK_LABEL_TEMPERATURE=0.1
BULK_LABEL_BATCH_SIZE=25
BULK_LABEL_CONCURRENCY=5
BULK_LABEL_INTER_BATCH_DELAY_S=0.5
BULK_LABEL_HTTP_TIMEOUT_S=60

# ── bulk-label-foods: runtime demotion multipliers ────────────────────────────
# These values document the production defaults used by js/algorithm.js.
# They are NOT automatically injected into the static frontend — they serve as
# documentation and can be overridden via window.BULK_LABEL_* in DevTools.
BULK_LABEL_DEMOTION_MEAL_SLOT=0.6
BULK_LABEL_DEMOTION_EXOTIC=0.7
BULK_LABEL_DEMOTION_RARE=0.5
